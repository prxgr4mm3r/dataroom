{
  "name": "dataroom-takehome",
  "private": true,
  "scripts": {
    "frontend": "npm --prefix frontend run dev",
    "frontend:build": "npm --prefix frontend run build",
    "backend": "cd backend && .venv/bin/flask --app run.py run --debug",
    "backend:init-db": "cd backend && .venv/bin/flask --app run.py init-db",
    "backend:test": "cd backend && .venv/bin/python -m unittest discover -s tests"
  }
}
