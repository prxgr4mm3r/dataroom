# frontend
VITE_API_BASE_URL=http://localhost:5000
VITE_MAX_IMPORT_FILE_SIZE_BYTES=4194304

# backend
FLASK_ENV=development
SECRET_KEY=change-me
DATABASE_URL=sqlite:///app.db
FRONTEND_URL=http://localhost:5173
UPLOAD_DIR=storage/uploads

# Google OAuth / Drive
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5000/api/integrations/google/callback

# Firebase Auth verification
FIREBASE_PROJECT_ID=
# JSON string or absolute path to service-account json
FIREBASE_CREDENTIALS_JSON=/run/secrets/firebase-service-account.json
AUTH_MAGIC_LINK_CONTINUE_URL=
AUTH_MAGIC_LINK_SUBJECT=Sign in to Dataroom.demo

# Magic link email transport (SMTP)
MAIL_SMTP_HOST=
MAIL_SMTP_PORT=587
MAIL_SMTP_USERNAME=
MAIL_SMTP_PASSWORD=
MAIL_SMTP_USE_TLS=true
MAIL_SMTP_USE_SSL=false
MAIL_FROM_EMAIL=
MAIL_FROM_NAME=Dataroom.demo
MAIL_REPLY_TO=

# Backend token-at-rest encryption
TOKEN_ENCRYPTION_KEY=change-me-encryption-key

# Optional tuning
OAUTH_STATE_TTL_SECONDS=600
MAX_IMPORT_FILE_SIZE_BYTES=4194304
REQUEST_TIMEOUT_SECONDS=20
